pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/JulioCesar9514/helloworld.git'
            }
        }
        stage('Hello World') {
            steps {
                echo 'Hello World'
                bat 'dir'
                bat 'echo Hola'
            }
        }

        stage('Instalar dependencias') {
            steps {
                bat 'echo Instalando dependencias... (simulado)'
            }
        }

        stage('Tests') {
            steps {
                bat 'echo Ejecutando tests... (simulado)'
            }
        }

        stage('Build') {
            steps {
                bat 'echo Construyendo aplicación...'
            }
        }
    }
}
