pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/JulioCesar9514/helloworld.git'
            }
        }

        stage('Instalar dependencias') {
            steps {
                sh 'pip install -r requirements.txt || true'
            }
        }

        stage('Tests') {
            steps {
                sh 'pytest || true'
            }
        }

        stage('Build') {
            steps {
                echo 'Construyendo aplicación...'
            }
        }
    }
}