pipeline {
    options {
        skipDefaultCheckout(true)
    }
    agent none   // Cambio any por none para poder asignar agentes por stage

    stages {

        stage('Get Code') {
            agent { label 'windows-agent' }   // AGENTE Built-In Node (localhost)
            tools {
                git 'Git-Windows'   // Configuración de la herramienta Git para el agente windows
            }
            steps {
                echo 'GET CODE'
                bat 'whoami'
                bat 'hostname'
                echo WORKSPACE

                git 'https://github.com/JulioCesar9514/helloworld.git'
            }
        }

        stage('Build') {
            agent { label 'windows-agent' }    // AGENTE Windows VM remota
            tools {
                git 'Git-Windows'   // Configuración de la herramienta Git para Windows
            }
            steps {
                echo 'BUILD'
                bat 'whoami'
                bat 'hostname'
                echo WORKSPACE
                echo 'Hola, no hay que compilar nada!!!'
                bat 'dir'
            }
        }

        stage('Tests') {
            agent { label 'linux-agent' }   // AGENTE Linux VM remota
            tools {
                git 'Git-Linux'
            }
            steps {
                git branch: 'master',
                    credentialsId: 'c7c18541-231c-4d4d-ab7a-bb0e534c7019',
                    url: 'https://github.com/JulioCesar9514/helloworld.git'
                echo 'ANALISIS ESTATICO'

                // Flake8
                sh '''
                    flake8 app --format=xml --output-file=flake8-report.xml || true
                '''

                // Bandit
                sh '''
                    bandit -r app -f xml -o bandit-report.xml || true
                '''

                // Warnings NG recogerá los XML generados
            }
        }

        stage('Performance') {
            agent { label 'linux-agent' }
            steps {
                echo 'PERFORMANCE TESTS'

                sh '''
                    jmeter -n -t test/performance/test-plan.jmx -l performance.jtl -e -o report
                '''

                perfReport errorFailedThreshold: 0, errorUnstableThreshold: 0, sourceDataFiles: 'performance.jtl'
            }
        }

        stage('Results') {
            agent { label 'built-in' }   // AGENTE built-in Node (localhost)
            steps {
                echo 'RESULTADOS'
                bat 'whoami'
                bat 'hostname'
                echo WORKSPACE

                recordIssues tools: [
                    flake8(pattern: 'flake8-report.xml'),
                    bandit(pattern: 'bandit-report.xml')
                ]

                perfReport errorFailedThreshold: 0, errorUnstableThreshold: 0, sourceDataFiles: 'performance.jtl'
            }
        }
    }
}