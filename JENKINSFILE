pipeline {
    agent any

     stages {
        stage('Get Code') {
            steps {
                // Obtener código del repo
                git 'https://github.com/JulioCesar9514/helloworld.git'
            }
        }

    stage('Build') {
        steps {
            echo 'Eyyyy, esto es Python. No hay que compilar nada!!!'
	    echo WORKSPACE
	    bat 'dir'
        }
    }

    stage('Tests')
    {
        parallel {

            stage('Unit') {
                steps {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {                        
                            bat '''
                                    set PYTHONPATH=%WORKSPACE%
                                    python -m pytest --junitxml=result-unit.xml test\\unit

                            '''
                    }
                }
            }
            
            stage('Rest') {
                steps {
                        bat '''
                            set FLASK_APP=app\\api.py
                            set FLASK_ENV=development
                            start /B python -m flask run                        
                            start /B java -jar C:\\UnirPracticas\\CP1\\wiremock\\wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
                            timeout /T 3
                            set PYTHONPATH=%WORKSPACE%
                            python -m pytest --junitxml=result-rest.xml test\\rest
                        '''
                }    
            }    
        }
    }
    
    stage ('Results') {
        steps {
            junit 'result*.xml'
        }
    }
  }
}
