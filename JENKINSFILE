pipeline {
    agent none   // Cambio any por none para poder asignar agentes por stage

    stages {
        stage('Get Code') {
            agent { label 'built-in' }   // AGENTE Built-In Node (localhost)
            steps {
                echo 'GET CODE'
                bat 'whoami'
                bat 'hostname'
                echo WORKSPACE

                git 'https://github.com/JulioCesar9514/helloworld.git'
            }
        }

        stage('Build') {
            agent { label 'windows-agent' }    // AGENTE Windows VM remota
            tools {
                git 'Git-Windows'   // Configuración de la herramienta Git para Windows
            }
            steps {
                echo 'BUILD'
                bat 'whoami'
                bat 'hostname'
                echo WORKSPACE
                echo 'Hola, no hay que compilar nada!!!'
                bat 'dir'
            }
        }

        stage('Tests') {
            parallel {
                stage('Unit') {
                    agent { label 'linux-agent' }   // AGENTE Linux VM remota
                    tools {
                        git 'Git-Linux'   // Configuración de la herramienta Git para Linux
                    }
                    steps {
                        echo 'UNIT TESTS'
                        sh 'whoami'
                        sh 'hostname'
                        sh 'echo $WORKSPACE'

                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                export PYTHONPATH=$WORKSPACE
                                python3 -m pytest --cov=app --cov-report=xml --junitxml=result-unit.xml test/unit
                            '''
                        }
                    }
                }

                stage('Rest') {
                    agent { label 'windows-agent' }  // AGENTE Windows VM remota
                    tools {
                        git 'Git-Windows'   // Configuración de la herramienta Git para Windows
                    }
                    steps {
                        echo 'REST TESTS'
                        bat 'whoami'
                        bat 'hostname'
                        echo WORKSPACE

                        bat '''
                            set FLASK_APP=app\\api.py
                            set FLASK_ENV=development
                            start /B python -m flask run
                            start /B java -jar C:\\UnirPracticas\\CP1\\wiremock\\wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
                            timeout /T 3
                            set PYTHONPATH=%WORKSPACE%
                            python -m pytest --cov=app --cov-report=xml --junitxml=result-rest.xml test\\rest
                        '''
                    }
                }
            }
        }

        stage('Results') {
            agent { label 'built-in' }   // AGENTE built-in Node (localhost)
            steps {
                echo 'RESULTADOS'
                bat 'whoami'
                bat 'hostname'
                echo WORKSPACE

                junit 'result*.xml'
                cobertura coberturaReportFile: 'coverage.xml'
            }
        }
    }
}
